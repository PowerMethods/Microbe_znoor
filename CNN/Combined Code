SEG_DIR = "/vol/projects/znoor/cnn_training/3class_exp/segments_256"

PHASE6_OUT = "/vol/projects/znoor/cnn_training/3class_exp_CNNBESTMODEL_Phase6"
PHASE7_OUT = "/vol/projects/znoor/cnn_training/3class_exp/Phase7_Finetune_Calibration"
FINAL_OUT  = "/vol/projects/znoor/cnn_training/3class_exp/FINAL_RESULTS"

RF_OUT     = f"{PHASE7_OUT}/RF_BASELINE_final"

NUM_CLASSES = 3
BATCH_SIZE = 16
DEVICE = "cuda" if torch.cuda.is_available() else "cpu"

os.makedirs(PHASE6_OUT, exist_ok=True)
os.makedirs(PHASE7_OUT, exist_ok=True)
os.makedirs(FINAL_OUT, exist_ok=True)
